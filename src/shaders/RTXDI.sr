// RTXDI.sr — RTXDI pass resource declarations.
// All structs, constants, cbuffers, and per-pass srinputs that were
// previously defined in SharedShaderInclude/ShaderParameters.h.
// Generated by srrhi into srrhi/cpp/RTXDI.h and srrhi/hlsl/RTXDI.hlsli.

#include "Common.sr"
#include "Instance.sr"
#include "Mesh.sr"

// ---------------------------------------------------------------------------
// External types used only as StructuredBuffer template args (no cbuffer checks)
// ---------------------------------------------------------------------------
extern RTXDI_PackedDIReservoir;
extern RTXDI_PackedGIReservoir;

// ---------------------------------------------------------------------------
// RTXDI SDK types — declared extern so srrhi uses the SDK's global-scope
// definitions rather than redefining them in namespace srrhi.
// The SDK headers (RtxdiParameters.h, ReSTIRDIParameters.h, etc.) must be
// included before srrhi/hlsl/RTXDI.hlsli in any shader that uses these types.
// ---------------------------------------------------------------------------
extern RTXDI_RuntimeParameters;
extern RTXDI_LightBufferRegion;
extern RTXDI_EnvironmentLightBufferParameters;
extern RTXDI_ReservoirBufferParameters;
extern RTXDI_BoilingFilterParameters;
extern RTXDI_LightBufferParameters;
extern RTXDI_RISBufferSegmentParameters;
extern RTXDI_DIBufferIndices;
extern RTXDI_DIInitialSamplingParameters;
extern RTXDI_DITemporalResamplingParameters;
extern RTXDI_DISpatialResamplingParameters;
extern RTXDI_DISpatioTemporalResamplingParameters;
extern RTXDI_ShadingParameters;
extern RTXDI_Parameters;
extern ReGIR_OnionLayerGroup;
extern ReGIR_OnionRing;
extern ReGIR_CommonParameters;
extern ReGIR_GridParameters;
extern ReGIR_OnionParameters;
extern ReGIR_Parameters;
extern RTXDI_GIBufferIndices;
extern RTXDI_GITemporalResamplingParameters;
extern RTXDI_GISpatialResamplingParameters;
extern RTXDI_GISpatioTemporalResamplingParameters;
extern RTXDI_GIFinalShadingParameters;
extern RTXDI_GIParameters;

struct PrepareLightsTask
{
    uint instanceAndGeometryIndex;
    uint triangleCount;
    uint lightBufferOffset;
    int  previousLightBufferOffset;
};

struct SecondaryGBufferData
{
    float3 worldPos;
    uint   normal;

    uint2  throughputAndFlags;
    uint   diffuseAlbedo;
    uint   specularAndRoughness;

    float3 emission;
    float  pdf;
};

struct PolymorphicLightInfo
{
    // uint4[0]
    float3 center;
    uint   colorTypeAndFlags;

    // uint4[1]
    uint direction1;
    uint direction2;
    uint scalars;
    uint logRadiance;

    // uint4[2]
    uint iesProfileIndex;
    uint primaryAxis;
    uint cosConeAngleAndSoftness;
    uint _padding;
};

struct SceneConstants
{
    uint  enableEnvironmentMap;
    uint  environmentMapTextureIndex;
    float environmentScale;
    float environmentRotation;

    uint  enableAlphaTestedGeometry;
    uint  enableTransparentGeometry;
    float sunIntensity;
    float _sunIntensityAlign;

    float3 sunDirection;
    float  _sunDirectionAlign;
};

// ---------------------------------------------------------------------------
// Constant buffers
// ---------------------------------------------------------------------------

cbuffer PrepareLightsConstants
{
    uint numTasks;
    uint currentFrameLightOffset;
    uint previousFrameLightOffset;
};

cbuffer ResamplingConstants
{
    PlanarViewConstants view;
    PlanarViewConstants prevView;
    PlanarViewConstants prevPrevView;
    RTXDI_RuntimeParameters runtimeParams;

    float4 reblurHitDistParams;

    uint enablePreviousTLAS;
    uint denoiserMode;
    uint discountNaiveSamples;
    uint enableBrdfIndirect;

    uint enableBrdfAdditiveBlend;
    uint enableAccumulation;
    uint directLightingMode;
    uint _pad0;

    SceneConstants sceneConstants;

    RTXDI_LightBufferParameters           lightBufferParams;
    RTXDI_RISBufferSegmentParameters      localLightsRISBufferSegmentParams;
    RTXDI_RISBufferSegmentParameters      environmentLightRISBufferSegmentParams;

    RTXDI_Parameters     restirDI;
    ReGIR_Parameters     regir;
    RTXDI_GIParameters   restirGI;

    uint  visualizeRegirCells;
    uint2 environmentPdfTextureSize;
    uint  _pad1;
    uint2 localLightPdfTextureSize;
    uint2 _pad2;
};

// ---------------------------------------------------------------------------
// RTXDIConstants — compile-time constants (replaces #defines in ShaderParameters.h)
// ---------------------------------------------------------------------------
srinput RTXDIConstants
{
    static const uint  TASK_PRIMITIVE_LIGHT_BIT         = 0x80000000u;

    static const uint  RTXDI_PRESAMPLING_GROUP_SIZE     = 256;
    static const uint  RTXDI_GRID_BUILD_GROUP_SIZE      = 256;
    static const uint  RTXDI_SCREEN_SPACE_GROUP_SIZE    = 8;
    static const uint  RTXDI_GRAD_FACTOR                = 3;
    static const float RTXDI_GRAD_STORAGE_SCALE         = 256.0f;
    static const float RTXDI_GRAD_MAX_VALUE             = 65504.0f;

    static const uint  INSTANCE_MASK_OPAQUE             = 0x01;
    static const uint  INSTANCE_MASK_ALPHA_TESTED       = 0x02;
    static const uint  INSTANCE_MASK_TRANSPARENT        = 0x04;
    static const uint  INSTANCE_MASK_ALL                = 0xFF;

    static const uint  DENOISER_MODE_OFF                = 0;
    static const uint  DENOISER_MODE_REBLUR             = 1;
    static const uint  DENOISER_MODE_RELAX              = 2;

    static const float BACKGROUND_DEPTH                 = 65504.0f;

    static const uint  INDIRECT_LIGHTING_MODE_NONE      = 0;
    static const uint  INDIRECT_LIGHTING_MODE_BRDF      = 1;
    static const uint  INDIRECT_LIGHTING_MODE_RESTIRGI  = 2;

    static const uint  kSecondaryGBuffer_IsSpecularRay  = 1;
    static const uint  kSecondaryGBuffer_IsDeltaSurface = 2;
    static const uint  kSecondaryGBuffer_IsEnvironmentMap = 4;

    static const uint  kPolymorphicLightTypeShift       = 24;
    static const uint  kPolymorphicLightTypeMask        = 0xf;
    static const uint  kPolymorphicLightShapingEnableBit      = 0x10000000u;
    static const uint  kPolymorphicLightIesProfileEnableBit   = 0x20000000u;
    static const float kPolymorphicLightMinLog2Radiance = -8.0f;
    static const float kPolymorphicLightMaxLog2Radiance = 40.0f;

    // PolymorphicLightType enum values (mirrors PolymorphicLightType in PolymorphicLight.hlsli)
    static const uint  kPolymorphicLightType_kSphere      = 0;
    static const uint  kPolymorphicLightType_kCylinder    = 1;
    static const uint  kPolymorphicLightType_kDisk        = 2;
    static const uint  kPolymorphicLightType_kRect        = 3;
    static const uint  kPolymorphicLightType_kTriangle    = 4;
    static const uint  kPolymorphicLightType_kDirectional = 5;
    static const uint  kPolymorphicLightType_kEnvironment = 6;
    static const uint  kPolymorphicLightType_kPoint       = 7;

    // DirectLightingMode enum values
    static const uint  DIRECT_LIGHTING_MODE_NONE   = 0;
    static const uint  DIRECT_LIGHTING_MODE_BRDF   = 1;
    static const uint  DIRECT_LIGHTING_MODE_RESTIR = 2;
};

// ---------------------------------------------------------------------------
// Per-pass srinputs
// Each pass in RTXDIRenderer gets its own srinput.
// ---------------------------------------------------------------------------

// ---- BuildEnvLightPDF pass ----
srinput BuildEnvLightPDFInputs
{
    ResamplingConstants m_Const;
    RWTexture2D<float>  m_EnvLightPdfMip0;
};

// ---- GenerateViewZ pass ----
srinput GenerateViewZInputs
{
    ResamplingConstants m_Const;
    Texture2D<float>    m_Depth;
    RWTexture2D<float>  m_LinearDepth;
};

// ---- PostprocessGBuffer pass ----
srinput PostprocessGBufferInputs
{
    ResamplingConstants m_Const;
    Texture2D<float>    m_ViewDepth;
    Texture2D<float2>   m_ORM;
    Texture2D<float2>   m_Normals;
};

// ---- PrepareLights pass ----
srinput PrepareLightsInputs
{
    PrepareLightsConstants                    m_Const;
    StructuredBuffer<PrepareLightsTask>       m_TaskBuffer;
    StructuredBuffer<PolymorphicLightInfo>    m_PrimitiveLightBuffer;
    StructuredBuffer<PerInstanceData>         m_InstanceData;
    StructuredBuffer<MeshData>                m_GeometryData;
    StructuredBuffer<MaterialConstants>       m_MaterialConstants;
    StructuredBuffer<uint>                    m_SceneIndices;
    StructuredBuffer<VertexQuantized>         m_SceneVertices;
    RWStructuredBuffer<PolymorphicLightInfo>  m_LightDataBuffer;
    RWBuffer<uint>                            m_LightIndexMappingBuffer;
    RWTexture2D<float4>                       m_LocalLightPdfTexture;
};

// ---- Main resampling passes (shared binding set) ----
srinput ResamplingPassInputs
{
    ResamplingConstants m_Const;

    Buffer<float2>                              m_NeighborOffsets;
    Texture2D<float>                            m_GBufferDepth;
    Texture2D<float2>                           m_GBufferGeoNormals;
    Texture2D<float4>                           m_GBufferAlbedo;
    Texture2D<float2>                           m_GBufferORM;
    Texture2D<float2>                           m_GBufferNormals;
    Texture2D<float2>                           m_PrevGBufferNormals;
    Texture2D<float2>                           m_PrevGBufferGeoNormals;
    Texture2D<float4>                           m_PrevGBufferAlbedo;
    Texture2D<float2>                           m_PrevGBufferORM;
    Texture2D<float4>                           m_MotionVectors;
    Texture2D<float3>                           m_DenoiserNormalRoughness;
    Texture2D<float>                            m_PrevGBufferDepth;
    Texture2D<float4>                            m_LocalLightPdfTexture;
    Texture2D<float4>                            m_EnvironmentPdfTexture;
    RaytracingAccelerationStructure             m_SceneBVH;
    RaytracingAccelerationStructure             m_PrevSceneBVH;
    StructuredBuffer<PolymorphicLightInfo>      m_LightDataBuffer;
    Texture2D<float4>                           m_GBufferEmissive;
    Buffer<uint>                                m_GeometryInstanceToLight;
    StructuredBuffer<PerInstanceData>           m_InstanceData;
    StructuredBuffer<MeshData>                  m_GeometryData;
    StructuredBuffer<MaterialConstants>         m_MaterialConstants;
    StructuredBuffer<uint>                      m_SceneIndices;
    StructuredBuffer<VertexQuantized>           m_SceneVertices;

    RWStructuredBuffer<RTXDI_PackedDIReservoir> m_LightReservoirs;
    RWStructuredBuffer<uint2>                   m_RisBuffer;
    RWStructuredBuffer<uint4>                   m_RisLightDataBuffer;
    RWStructuredBuffer<RTXDI_PackedGIReservoir> m_GIReservoirs;
    RWStructuredBuffer<SecondaryGBufferData>    m_SecondaryGBuffer;
    RWTexture2D<float4>                         m_DiffuseLighting;
    RWTexture2D<float4>                         m_SpecularLighting;
};

// ---- CompositingPass ----
srinput CompositingPassInputs
{
    ResamplingConstants m_Const;                    // b0
    Texture2D<float4>   m_GBufferAlbedo;            // t0
    Texture2D<float2>   m_GBufferORM;               // t1
    Texture2D<float4>   m_GBufferEmissive;          // t2
    Texture2D<float4>   m_DiffuseIllumination;      // t3
    Texture2D<float4>   m_SpecularIllumination;     // t4
};
